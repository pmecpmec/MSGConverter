# MSG-3 to Maximo Converter – Environment Variables
# Kopieer dit bestand naar .env en vul de waarden in:
#   copy .env.example .env
#
# NOOIT .env committen naar Git (staat al in .gitignore)!

# ──────────────────────────────────────────────────────────
# Maximo verbinding
# ──────────────────────────────────────────────────────────

# Basis-URL van de Maximo-instantie (zonder trailing slash)
MAXIMO_BASE_URL=https://maximo.babcock.local

# Authenticatie: kies één van de twee methodes

# Optie 1 – API Key (aanbevolen)
MAXIMO_API_KEY=your-api-key-here

# Optie 2 – Basic Auth (legacy)
# MAXIMO_USERNAME=maxadmin
# MAXIMO_PASSWORD=your-password-here

# ──────────────────────────────────────────────────────────
# Maximo configuratie
# ──────────────────────────────────────────────────────────

# Organisatie ID (bijv. SCHIPHOL)
MAXIMO_ORG_ID=SCHIPHOL

# Item Set (bijv. MSG3-MAINT)
MAXIMO_ITEM_SET=MSG3-MAINT

# ──────────────────────────────────────────────────────────
# Applicatie instellingen (optioneel)
# ──────────────────────────────────────────────────────────

# Log niveau: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log naar bestand (pad, optioneel – leeg = alleen stdout)
# LOG_FILE=logs/msgconverter.log

# Tijdzone
TZ=Europe/Amsterdam
